{
  "name": "jobpilot-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:demo": "vite --host 0.0.0.0 --mode demo",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && vite build --mode demo",
    "preview": "vite preview --host 0.0.0.0",
    "preview:demo": "vite preview --host 0.0.0.0 --mode demo",
    "api": "node server/index.mjs",
    "api:check": "node server/check.mjs",
    "audit:v07": "node tools/v07_webapp_audit.cjs",
    "audit:v07.2": "node tools/v07_2_acceptance_audit.cjs",
    "audit": "npm run audit:v07 && npm run audit:v07.2"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright-core": "^1.60.0"
  }
}
